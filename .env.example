# ─────────────────────────────────────────────────────────────────────────────
# DJANGO
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL)
# Estos nombres deben coincidir con los usados en settings.py
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=paros_produccion
DB_USER=postgres
DB_PASSWORD=cambia-esta-contraseña
DB_HOST=db
DB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# NOTAS
# - Copia este archivo como .env y rellena los valores reales
# - NUNCA subas el archivo .env al repositorio
# - DB_HOST debe ser "db" cuando se ejecuta con Docker Compose
# - DB_HOST debe ser "localhost" cuando se ejecuta en local sin Docker
# ─────────────────────────────────────────────────────────────────────────────
